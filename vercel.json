{
  "crons": [
    {
      "path": "/api/cron/archive",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "api/v1/events.js": { "memory": 256, "maxDuration": 10 },
    "api/v1/[...otel].js": { "memory": 512, "maxDuration": 30 },
    "api/workflows/[id]/discover.js": { "memory": 512, "maxDuration": 30 }
  },
  "rewrites": [
    {
      "source": "/((?!api/|assets/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ]
}